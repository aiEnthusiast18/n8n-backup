    {
      "parameters": {
        "jsCode": "// Parse the AI output and prepare structured data\nconst aiOutput = $input.first().json.output;\nlet parsedOutput;\n\ntry {\n  // Try to parse as JSON first\n  parsedOutput = JSON.parse(aiOutput);\n} catch (e) {\n  // Fallback: extract content using regex if not valid JSON\n  parsedOutput = {\n    caption: aiOutput.match(/caption[\"']?:\\s*[\"']([^\"']+)[\"']/i)?.[1] || aiOutput,\n    visualDescription: aiOutput.match(/visualDescription[\"']?:\\s*[\"']([^\"']+)[\"']/i)?.[1] || 'Professional healthcare image for senior care',\n    hashtags: aiOutput.match(/hashtags[\"']?:\\s*[\"']([^\"']+)[\"']/i)?.[1] || '#RightAtHomeWinnipeg #SeniorCare #HomeCareWinnipeg',\n    callToAction: aiOutput.match(/callToAction[\"']?:\\s*[\"']([^\"']+)[\"']/i)?.[1] || 'Contact us today at (204) 318-5554'\n  };\n}\n\n// Add metadata\nparsedOutput.topic = $input.first().json.topic;\nparsedOutput.postType = $input.first().json.postType;\nparsedOutput.scheduledDate = $now.toFormat('YYYY-MM-DD');\nparsedOutput.resourceLink = $input.first().json.resourceLink;\n\nreturn parsedOutput;"
      },
