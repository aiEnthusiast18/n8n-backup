    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate a social media post for Right at Home Winnipeg.\n\nTopic: {{ $json.topic }}\nPost Type: {{ $json.postType }}\nCalendar Event: {{ $json.calendarEvent }}\nResource Link: {{ $json.resourceLink }}\nDate: {{ $now.format('MMMM DD, YYYY') }}\n\nGenerate:\n1. Instagram/Facebook caption (100-150 words)\n2. Visual description for image generation\n3. Hashtags (5-7 relevant ones)\n4. Call to action",
        "options": {
          "systemMessage": "You are a professional social media content creator for Right at Home Winnipeg, a trusted in-home senior care agency. Your content should be:\n\n- Warm, empathetic, and human\n- Professional yet approachable\n- Focused on dignity, independence, and quality of life\n- Never using terms like 'elderly', 'burden', or 'suffering'\n- Always including the company phone: (204) 318-5554\n- Ending with a clear call to action and website link\n\nBrand voice: compassionate, trustworthy, community-focused, supportive\n\nAlways include hashtags: #RightAtHomeWinnipeg #SeniorCare #HomeCareWinnipeg\n\nOutput format JSON:\n{\n  \"caption\": \"[Instagram/Facebook caption text]\",\n  \"visualDescription\": \"[Detailed description for image generation]\",\n  \"hashtags\": \"[hashtag list]\",\n  \"callToAction\": \"[CTA text]\"\n}"
        }
      },
      "id": "a80974e6-a3c6-4cbe-9dca-08c61c6442e3",
      "name": "Generate Post Content",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
      "position": [
        400,
        240
      ]
    },
    {
