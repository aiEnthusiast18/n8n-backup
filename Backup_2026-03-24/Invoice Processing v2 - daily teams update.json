    {
      "parameters": {
        "jsCode": "// Process today's invoices (already filtered by Google Sheets)\nconst today = new Date().toLocaleDateString('en-CA');\nconst items = $input.all();\n\n// Check if any invoices were returned from the filter\nif (items.length === 0) {\n  return [{\n    json: {\n      totalInvoices: 0,\n      totalAmount: 0,\n      vendors: [],\n      message: `📊 **Daily Invoice Processing Summary - ${today}**\\n\\n❌ No invoices processed today.`\n    }\n  }];\n}\n\n// All items are already today's invoices (thanks to Google Sheets filter)\nconst todaysInvoices = items;\nconst totalInvoices = todaysInvoices.length;\n\n// Calculate statistics\nlet totalAmount = 0;\nconst vendorCounts = {};\nconst invoiceDetails = [];\n\nfor (const invoice of todaysInvoices) {\n  const amount = parseFloat(invoice.json['Total Amount']) || 0;\n  totalAmount += amount;\n  \n  const vendor = invoice.json['Vendor Name'] || 'Unknown';\n  vendorCounts[vendor] = (vendorCounts[vendor] || 0) + 1;\n  \n  invoiceDetails.push({\n    invoiceNumber: invoice.json['Invoice Number'],\n    vendor: vendor,\n    amount: amount\n  });\n}\n\n// Format vendor summary\nconst vendorSummary = Object.entries(vendorCounts)\n  .map(([vendor, count]) => `• ${vendor}: ${count} invoice${count > 1 ? 's' : ''}`)\n  .join('\\n');\n\n// Format invoice details\nconst invoiceList = invoiceDetails\n  .map(inv => `• ${inv.invoiceNumber} - ${inv.vendor} - $${inv.amount.toFixed(2)}`)\n  .join('\\n');\n\n// Create Teams message\nconst message = `📊 **Daily Invoice Processing Summary - ${today}**\n\n✅ **Total Invoices Processed:** ${totalInvoices}\n💰 **Total Amount:** $${totalAmount.toFixed(2)}\n\n📋 **Vendor Breakdown:**\n${vendorSummary}\n\n📄 **Invoice Details:**\n${invoiceList}\n\n---\n*Automated summary from n8n Invoice Processing Workflow*`;\n\nreturn [{\n  json: {\n    totalInvoices,\n    totalAmount,\n    vendors: Object.keys(vendorCounts),\n    message,\n    invoiceDetails\n  }\n}];"
      },
