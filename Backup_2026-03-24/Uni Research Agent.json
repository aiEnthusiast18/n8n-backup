    {
      "parameters": {
        "functionCode": "const data = $node['Structure Research'].json.choices[0].message.content;\nlet parsedData;\ntry {\n  parsedData = JSON.parse(data);\n} catch (e) {\n  parsedData = { university: 'University', deadlines: [] };\n}\n\nconst sheetData = [['Descriptor', 'Personal Deadline', 'Hard Deadline']];\n\nif (parsedData.deadlines) {\n  parsedData.deadlines.forEach(deadline => {\n    sheetData.push([deadline, '', '']);\n  });\n}\n\nreturn { json: { sheetData, title: parsedData.university + ' Deadlines' } };"
      },
