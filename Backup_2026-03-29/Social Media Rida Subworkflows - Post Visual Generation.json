        "jsCode": "// n8n Code node\n// Merges all incoming items into a single item\n\nconst merged = {};\n\nfor (const item of $input.all()) {\n  Object.assign(merged, item.json);\n}\n\nreturn [\n  {\n    json: merged\n  }\n];"
      },
