    {
      "parameters": {
        "content": "## PDF Text Extraction Workflow\n\n**Upload PDF via POST:**\n- Endpoint: `/webhook/pdf-upload`\n- Method: POST\n- Body: Include PDF file as base64 or binary\n- Field name: `pdfFile`\n\n**Process:**\n1. Receive PDF file\n2. Convert to text using OpenAI or Google Document AI\n3. Clean and format extracted text\n4. Return structured response",
        "height": 300,
        "width": 400
      },
      "id": "48000134-f850-4267-bb9a-f0243af3a1f9",
      "name": "PDF Processing Instructions",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -640,
        -288
      ]
    },
    {
      "parameters": {
        "functionCode": "// Validate PDF input and prepare for processing\nconst items = [];\n\nfor (const item of $input.all()) {\n  try {\n    const input = item.json;\n    \n    // Check if PDF file is provided\n    if (!input.pdfFile && !input.file) {\n      throw new Error('No PDF file provided. Please include pdfFile or file in request body.');\n    }\n    \n    // Handle different input formats\n    let pdfData = input.pdfFile || input.file;\n    let filename = input.filename || 'document.pdf';\n    \n    // If it's base64 data, extract it\n    if (typeof pdfData === 'string' && pdfData.includes('base64,')) {\n      pdfData = pdfData.split('base64,')[1];\n    }\n    \n    items.push({\n      json: {\n        pdfData: pdfData,\n        filename: filename,\n        timestamp: new Date().toISOString(),\n        originalInput: input\n      }\n    });\n    \n  } catch (error) {\n    items.push({\n      json: {\n        error: true,\n        message: error.message,\n        timestamp: new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn items;"
      },
      "id": "3b0a8390-ff4b-4bad-97b8-a4e857181e1b",
      "name": "Validate PDF Input",
      "type": "n8n-nodes-base.function",
