    {
      "parameters": {
        "model": "chatgpt-4o-latest",
        "prompt": "=Extract all text content from this PDF file and return it in a structured JSON format. Include:\n1. All text content (preserve paragraphs and formatting where possible)\n2. Any headers or titles identified\n3. Page breaks or section dividers\n4. Metadata if available\n\nReturn the response in this JSON structure:\n{\n  \"success\": true,\n  \"extractedText\": \"[full text content]\",\n  \"sections\": [\n    {\n      \"type\": \"header|paragraph|list\",\n      \"content\": \"text content\",\n      \"page\": 1\n    }\n  ],\n  \"metadata\": {\n    \"totalPages\": 0,\n    \"totalCharacters\": 0,\n    \"language\": \"detected language\"\n  }\n}\n\nPDF Data: {{ $json.pdfData }}",
        "options": {},
        "requestOptions": {}
      },
      "id": "b73e1eb6-a410-4a0b-9969-d16afcd091bc",
      "name": "Extract Text with OpenAI",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        -2656,
        -656
      ],
      "credentials": {
        "openAiApi": {
          "id": "OhcxKqaJMIt2UKDI",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "// Process OpenAI response and clean extracted text\nconst items = [];\n\nfor (const item of $input.all()) {\n  try {\n    let extractedData;\n    \n    // Handle OpenAI response\n    if (item.json.choices && item.json.choices[0]) {\n      const content = item.json.choices[0].message.content;\n      extractedData = typeof content === 'string' ? JSON.parse(content) : content;\n    } else if (item.json.text) {\n      // Alternative response format\n      extractedData = JSON.parse(item.json.text);\n    } else {\n      throw new Error('Unexpected response format from OpenAI');\n    }\n    \n    // Validate and clean extracted data\n    const cleanedText = extractedData.extractedText || '';\n    const sections = extractedData.sections || [];\n    const metadata = extractedData.metadata || {};\n    \n    // Calculate additional metadata\n    const wordCount = cleanedText.split(/\\s+/).filter(word => word.length > 0).length;\n    const lineCount = cleanedText.split('\\n').length;\n    \n    items.push({\n      json: {\n        success: true,\n        extractedText: cleanedText,\n        sections: sections,\n        metadata: {\n          ...metadata,\n          wordCount: wordCount,\n          lineCount: lineCount,\n          characterCount: cleanedText.length,\n          extractionMethod: 'OpenAI GPT-4',\n          processedAt: new Date().toISOString()\n        },\n        originalFilename: $node['Validate PDF Input'].json.filename\n      }\n    });\n    \n  } catch (error) {\n    console.error('Error processing OpenAI response:', error);\n    \n    items.push({\n      json: {\n        success: false,\n        error: 'Failed to process PDF text extraction',\n        message: error.message,\n        rawResponse: item.json\n      }\n    });\n  }\n}\n\nreturn items;"
      },
      "id": "91379dbd-803f-438c-a362-1457314fec55",
      "name": "Process OpenAI Response",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        -2448,
        -656
      ]
    },
    {
      "parameters": {
        "functionCode": "// Format final response with extracted text and metadata\nconst items = [];\n\nfor (const item of $input.all()) {\n  try {\n    const data = item.json;\n    \n    if (data.success) {\n      // Create comprehensive response\n      const response = {\n        success: true,\n        message: 'PDF text extraction completed successfully',\n        data: {\n          filename: data.originalFilename,\n          extractedText: data.extractedText,\n          sections: data.sections,\n          metadata: data.metadata,\n          summary: {\n            totalWords: data.metadata.wordCount,\n            totalLines: data.metadata.lineCount,\n            totalCharacters: data.metadata.characterCount,\n            extractionMethod: data.metadata.extractionMethod,\n            processedAt: data.metadata.processedAt\n          }\n        }\n      };\n      \n      items.push({ json: response });\n      \n    } else {\n      // Error response\n      items.push({\n        json: {\n          success: false,\n          message: 'PDF text extraction failed',\n          error: data.error || data.message,\n          details: data.rawResponse\n        }\n      });\n    }\n    \n  } catch (error) {\n    items.push({\n      json: {\n        success: false,\n        message: 'Failed to format response',\n        error: error.message\n      }\n    });\n  }\n}\n\nreturn items;"
      },
