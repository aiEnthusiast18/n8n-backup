    {
      "parameters": {
        "jsCode": "// Access all input items\nconst items = $input.all();\n\n// Process each item\nconst newItems = items.map(item => {\n  // Extract the scheduled date (assuming it's in Excel serial format)\n  const excelSerialDate = Number(item.json['Scheduled Post Date and Time']);\n  \n  // Convert Excel serial date to JavaScript Date\n  // Excel serial date starts from 1900-01-01 (25569 days after 1970-01-01)\n  const milliseconds = (excelSerialDate - 25569) * 86400 * 1000;\n  let date = new Date(milliseconds);\n  \n  // Add 5 hours\n  date.setHours(date.getHours() + 5);\n  \n  // Format the date to ISO 8601 string with timezone\n  const formattedDate = date.toISOString();\n  \n  // Return a new object with the original data plus the formatted date\n  return {\n    ...item.json,\n    'Formatted Date': formattedDate\n  };\n});\n\n// Return the array of processed items\nreturn newItems;"
      },
