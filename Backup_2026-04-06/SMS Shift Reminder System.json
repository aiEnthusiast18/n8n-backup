      "id": "dd3cb80b-ba1a-45af-b36b-a6e53f949cd6",
      "name": "Remove Duplicates1",
      "type": "n8n-nodes-base.removeDuplicates",
      "typeVersion": 1.1,
      "position": [
        32,
        2512
      ],
      "disabled": true
    },
    {
      "parameters": {
        "functionCode": "// Parameters - adjust interval here\nconst REMINDER_INTERVAL_HOURS = 24;\n\n// Parse Employee Contacts\nconst contactsRaw = items[0].json.value || items[0].json.rows || items[0].json;\nconst contacts = Array.isArray(contactsRaw) ? contactsRaw : contactsRaw.data;\n// Parse Shift Schedule\nconst shiftsRaw = items[1].json.value || items[1].json.rows || items[1].json;\nconst shifts = Array.isArray(shiftsRaw) ? shiftsRaw : shiftsRaw.data;\n\nconst now = new Date();\nconst targetMin = new Date(now.getTime() + REMINDER_INTERVAL_HOURS * 60 * 60 * 1000);\nconst targetMax = new Date(targetMin.getTime() + 59 * 60 * 1000); // 1 hour window\n\nlet reminders = [];\nlet sentHashes = new Set();\n\nfor (const shift of shifts) {\n  // Assume column keys match label names\n  if (shift.Status !== 'Scheduled') continue;\n  \n  // Parse Date + In to get start time\n  const shiftDate = shift.Date;\n  const shiftIn = shift.In;\n  // Example format: '2025-11-03' and '09:00'\n  const shiftDateTimeStr = `${shiftDate}T${shiftIn}:00-06:00`;\n  const shiftDateTime = new Date(shiftDateTimeStr);\n\n  if (shiftDateTime >= targetMin && shiftDateTime <= targetMax) {\n    // Find contact info\n    const contact = contacts.find(c => c['Employee Id'] === shift['Employee Id']);\n    if (contact && contact['emp phone number']) {\n      // Use Account Id + Date + In + Employee Id to de-duplicate\n      const hash = `${shift['Account Id']}_${shiftDate}_${shiftIn}_${shift['Employee Id']}`;\n      if (!sentHashes.has(hash)) {\n        reminders.push({\n          phone: contact['emp phone number'],\n          message: `REMINDER: You have a shift from ${shift.In} - ${shift.Out} on ${shift.Date} at ${shift.Client} (${shift['clt address']})`,\n          hash\n        });\n        sentHashes.add(hash);\n      }\n    }\n  }\n}\n\nreturn reminders.map(r => ({ json: r }));\n"
      },
