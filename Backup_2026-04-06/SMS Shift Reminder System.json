      "id": "2290a5f3-70f5-46e3-a97b-fcfc6c24d30a",
      "name": "Daily Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        112,
        1488
      ]
    },
    {
      "parameters": {
        "jsCode": "const { DateTime } = globalThis.luxon;\n\n// Get configuration from the Config node\nconst allItems = $input.all();\nconst config = $node[\"Configuration\"].json;\nconst hoursBeforeShift = config.hoursBeforeShift || 24;\nconst timezone = config.timezone || 'America/Chicago';\nconst debugMode = config.debugMode || false;\n\nconst filteredItems = [];\nconst errors = [];\n\nfor (const item of allItems) {\n  try {\n    const shiftDate = item.json['Date'];\n    const shiftInTime = item.json['In'];\n    const status = item.json['Status'];\n    const employeeId = item.json['Employee Id'];\n    \n    // Skip if shift is not scheduled\n    if (status !== 'Scheduled' && status !== 'SCHEDULED') {\n      if (debugMode) {\n        console.log(`Skipping shift for employee ${employeeId}: Status is ${status}`);\n      }\n      continue;\n    }\n    \n    // Skip if date or time is missing\n    if (!shiftDate || !shiftInTime) {\n      errors.push({\n        employeeId,\n        error: 'Missing date or time',\n        date: shiftDate,\n        time: shiftInTime\n      });\n      continue;\n    }\n    \n    // Parse the shift date and time\n    const dateTimeString = `${shiftDate} ${shiftInTime}`;\n    \n    // Try multiple date formats\n    let shiftDateTime;\n    const formats = [\n      'M/d/yyyy h:mm a',\n      'MM/dd/yyyy h:mm a',\n      'M/d/yyyy HH:mm',\n      'MM/dd/yyyy HH:mm'\n    ];\n    \n    for (const format of formats) {\n      shiftDateTime = DateTime.fromFormat(\n        dateTimeString, \n        format,\n        { zone: timezone }\n      );\n      if (shiftDateTime.isValid) break;\n    }\n    \n    if (!shiftDateTime || !shiftDateTime.isValid) {\n      errors.push({\n        employeeId,\n        error: 'Invalid date/time format',\n        dateTimeString,\n        invalidReason: shiftDateTime?.invalidReason\n      });\n      continue;\n    }\n    \n    // Get current time in the same timezone\n    const now = DateTime.now().setZone(timezone);\n    \n    // Calculate hours until shift\n    const hoursUntilShift = shiftDateTime.diff(now, 'hours').hours;\n    \n    // Check if shift is within the reminder window (±30 minutes)\n    if (hoursUntilShift >= (hoursBeforeShift - 0.5) && \n        hoursUntilShift <= (hoursBeforeShift + 0.5)) {\n      \n      // Add formatted datetime to the data\n      item.json.shiftDateTime = shiftDateTime.toISO();\n      item.json.formattedDate = shiftDateTime.toFormat('EEEE, MMMM d');\n      item.json.formattedTime = shiftDateTime.toFormat('h:mm a');\n      item.json.hoursUntilShift = Math.round(hoursUntilShift);\n      item.json.shouldSendReminder = true;\n      \n      filteredItems.push(item);\n      \n      if (debugMode) {\n        console.log(`Reminder scheduled for ${item.json['Employee']} - Shift in ${hoursUntilShift.toFixed(1)} hours`);\n      }\n    } else if (debugMode) {\n      console.log(`No reminder for ${item.json['Employee']} - Shift in ${hoursUntilShift.toFixed(1)} hours (outside window)`);\n    }\n    \n  } catch (error) {\n    errors.push({\n      employeeId: item.json['Employee Id'],\n      error: error.message,\n      data: item.json\n    });\n  }\n}\n\n// Log errors if any\nif (errors.length > 0) {\n  console.log('Processing errors:', JSON.stringify(errors, null, 2));\n}\n\nif (debugMode) {\n  console.log(`Filtered ${filteredItems.length} shifts from ${allItems.length} total`);\n}\n\nreturn filteredItems;"
      },
