      "id": "60980a65-8ca9-4e18-8d36-48ec1bf65e94",
      "name": "Check Phone Number",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1312,
        1568
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get the phone number from either field\nlet phoneNumber = $json['emp phone number'] || $json['phone'];\n\nif (!phoneNumber) {\n  throw new Error('No phone number found');\n}\n\n// Convert to string in case it's a number\nphoneNumber = String(phoneNumber);\n\n// Remove all non-digit characters\nphoneNumber = phoneNumber.replace(/\\D/g, '');\n\n// Validate phone number length\nif (phoneNumber.length < 10) {\n  throw new Error(`Invalid phone number: ${phoneNumber} (too short)`);\n}\n\n// Add country code if not present (assuming US +1)\nif (phoneNumber.length === 10) {\n  phoneNumber = '1' + phoneNumber;\n}\n\n// Format with + prefix\nif (!phoneNumber.startsWith('+')) {\n  phoneNumber = '+' + phoneNumber;\n}\n\n// Validate final format\nif (!phoneNumber.match(/^\\+1\\d{10}$/)) {\n  console.warn(`Phone number may not be properly formatted: ${phoneNumber}`);\n}\n\n// Add formatted phone number to the data\n$json.formattedPhoneNumber = phoneNumber;\n$json.originalPhoneNumber = $json['emp phone number'];\n\nreturn $json;"
      },
      "id": "4f90ff2e-2d89-4ffe-866e-5e64d90a5677",
      "name": "Format Phone Number",
