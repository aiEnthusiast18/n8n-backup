    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get configuration\nconst config = $node[\"Configuration1\"].json;\nconst hoursBeforeShift = config.hoursBeforeShift || 24;\nconst timezone = config.timezone || 'America/Chicago';\n\n// Import DateTime from Luxon\nconst { DateTime } = require('luxon');\n\n// Get current item data\nconst shiftDate = $json['Date'];\nconst shiftInTime = $json['In'];\nconst status = $json['Status'];\n\n// Skip if shift is not scheduled\nif (status !== 'Scheduled' && status !== 'SCHEDULED') {\n  return null;\n}\n\n// Parse the shift date and time\n// Assuming Date is in format MM/DD/YYYY and In is in format HH:MM AM/PM\ntry {\n  // Combine date and time\n  const dateTimeString = `${shiftDate} ${shiftInTime}`;\n  \n  // Parse the datetime in the specified timezone\n  const shiftDateTime = DateTime.fromFormat(\n    dateTimeString, \n    'M/d/yyyy h:mm a',\n    { zone: timezone }\n  );\n  \n  if (!shiftDateTime.isValid) {\n    console.log('Invalid date/time:', dateTimeString, shiftDateTime.invalidExplanation);\n    return null;\n  }\n  \n  // Get current time in the same timezone\n  const now = DateTime.now().setZone(timezone);\n  \n  // Calculate hours until shift\n  const hoursUntilShift = shiftDateTime.diff(now, 'hours').hours;\n  \n  // Check if shift is within the reminder window\n  // We want shifts that are between (hoursBeforeShift - 0.5) and (hoursBeforeShift + 0.5) hours away\n  // This gives us a 1-hour window to catch the shift\n  if (hoursUntilShift >= (hoursBeforeShift - 0.5) && hoursUntilShift <= (hoursBeforeShift + 0.5)) {\n    // Add formatted datetime to the data\n    $json.shiftDateTime = shiftDateTime.toISO();\n    $json.formattedDate = shiftDateTime.toFormat('EEEE, MMMM d');\n    $json.hoursUntilShift = Math.round(hoursUntilShift);\n    $json.shouldSendReminder = true;\n    \n    return $json;\n  }\n  \n} catch (error) {\n  console.log('Error processing shift:', error.message);\n  return null;\n}\n\n// Don't send reminder for this shift\nreturn null;"
      },
      "id": "349b8704-b0c1-4418-a294-0ef3ee1067eb",
      "name": "Filter Upcoming Shifts1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -976,
        2560
      ],
      "disabled": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get the phone number\nlet phoneNumber = $json['emp phone number'];\n\n// Remove all non-digit characters\nphoneNumber = phoneNumber.replace(/\\D/g, '');\n\n// Add country code if not present (assuming US +1)\nif (phoneNumber.length === 10) {\n  phoneNumber = '1' + phoneNumber;\n}\n\n// Format with + prefix\nif (!phoneNumber.startsWith('+')) {\n  phoneNumber = '+' + phoneNumber;\n}\n\n// Add formatted phone number to the data\n$json.formattedPhoneNumber = phoneNumber;\n\nreturn $json;"
      },
