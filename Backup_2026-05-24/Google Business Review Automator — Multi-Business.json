    {
      "parameters": {
        "jsCode": "// ── BUSINESS CONFIGURATION ────────────────────────────────────────────────\n// Fill in your real Location IDs from Google Business Profile.\n// GBP Dashboard → Business → Info → Location ID\n// Format: accounts/ACCOUNT_ID/locations/LOCATION_ID\n//\n// ✅ Start with 204 IT Solutions to test, then uncomment the live businesses.\n\nconst ALERT_EMAIL = 'your@email.com'; // ← Replace with your email address\n\nreturn [\n  {\n    json: {\n      businessName: '204 IT Solutions',\n      locationId: 'accounts/YOUR_ACCOUNT_ID/locations/YOUR_204IT_LOCATION_ID',\n      alertEmail: ALERT_EMAIL\n    }\n  },\n  {\n    json: {\n      businessName: 'Anago Cleaning Systems / Anago of Manitoba',\n      locationId: 'accounts/YOUR_ACCOUNT_ID/locations/YOUR_ANAGO_LOCATION_ID',\n      alertEmail: ALERT_EMAIL\n    }\n  },\n  {\n    json: {\n      businessName: 'Right At Home Winnipeg',\n      locationId: 'accounts/YOUR_ACCOUNT_ID/locations/YOUR_RIGHTATHOME_LOCATION_ID',\n      alertEmail: ALERT_EMAIL\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1536,
        144
      ],
      "id": "af3c77f5-66c7-4319-b17b-f946599de21e",
      "name": "Business Configs"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
