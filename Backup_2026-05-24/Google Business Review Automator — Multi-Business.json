      "id": "d86e2778-ade8-4945-bd0e-a1cc3b54991d",
      "name": "Get Reviews"
    },
    {
      "parameters": {
        "jsCode": "// Attach business context to every review item.\n// Also normalises starRating from GBP's string enum (ONE/TWO/.../FIVE) to a number.\n// FIX: the original workflow compared star ratings to numbers — GBP returns strings.\n\nconst ratingMap = { ONE: 1, TWO: 2, THREE: 3, FOUR: 4, FIVE: 5 };\n\nconst businessName = $('Loop Businesses').first().json.businessName;\nconst locationId   = $('Loop Businesses').first().json.locationId;\nconst alertEmail   = $('Loop Businesses').first().json.alertEmail;\n\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    businessName,\n    locationId,\n    alertEmail,\n    starRatingNum: ratingMap[item.json.starRating] ?? 0,\n    reviewerName:  item.json.reviewer?.displayName ?? 'A customer',\n    reviewText:    item.json.comment ?? '(no review text left)'\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -880,
        144
      ],
      "id": "3330f029-e094-4c55-b15c-65a8f116687a",
      "name": "Tag Reviews"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "no-reply-check",
              "leftValue": "={{ $json.reviewReply }}",
              "rightValue": "",
              "operator": {
                "type": "object",
                "operation": "empty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -656,
        144
      ],
      "id": "48ef3386-9499-471a-81dc-51c0555c5a80",
      "name": "Unanswered Only?"
    },
    {
      "parameters": {
        "jsCode": "// ── DEDUPLICATION ─────────────────────────────────────────────────────────\n// Uses n8n static workflow data — no external database needed.\n// Tracks processed review IDs with timestamps.\n// Auto-prunes entries older than 90 days to prevent unbounded growth.\n//\n// WHY THIS IS NEEDED:\n// Negative/neutral reviews never get a reply posted, so reviewReply stays null.\n// Without this, the same negative review would trigger a new email every hour.\n\nconst staticData = $getWorkflowStaticData('global');\nconst now = Date.now();\nconst PRUNE_AGE_MS = 90 * 24 * 60 * 60 * 1000;\n\nif (!staticData.processed) staticData.processed = {};\n\n// Prune stale entries\nfor (const id of Object.keys(staticData.processed)) {\n  if (now - staticData.processed[id] > PRUNE_AGE_MS) {\n    delete staticData.processed[id];\n  }\n}\n\nconst newItems = [];\nfor (const item of items) {\n  const reviewId = item.json.name; // GBP review resource name is the unique identifier\n  if (staticData.processed[reviewId]) {\n    continue; // Already processed — skip silently\n  }\n  staticData.processed[reviewId] = now;\n  newItems.push(item);\n}\n\nreturn newItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        144
      ],
      "id": "4f8eed99-302c-4d16-a814-786cb75193b7",
      "name": "Dedup Check"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.starRatingNum }}",
                    "rightValue": 4,
                    "operator": {
                      "type": "number",
                      "operation": "gte"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Positive"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.starRatingNum }}",
                    "rightValue": 3,
                    "operator": {
                      "type": "number",
                      "operation": "lte"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "NeutralNegative"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
