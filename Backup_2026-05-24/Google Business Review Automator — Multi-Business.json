    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "pos-prompt",
              "name": "promptText",
              "value": "={{ 'TASK: Write a warm, genuine reply to this Google review for ' + $json.businessName + '.\\n\\nRULES:\\n- 2 to 4 sentences only\\n- Thank the reviewer by first name if available\\n- Reference at least one specific detail from their review to show you read it\\n- End with a friendly invitation to return or use the service again\\n- Write in first-person plural (we / our)\\n- No hashtags, emojis, or hollow phrases like \"We value your feedback\"\\n- Sound like a real person, not a template\\n\\nREVIEW DETAILS:\\nBusiness: ' + $json.businessName + '\\nReviewer: ' + $json.reviewerName + '\\nRating: ' + $json.starRating + '\\nReview text: ' + $json.reviewText + '\\n\\nWrite the reply now. Reply text only — no labels, no quotation marks.' }}",
              "type": "string"
            },
