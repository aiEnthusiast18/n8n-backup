ta__x0036_0DayEmailSent) reason = '60-day email already sent';\n    else if (daysSinceStart >= 90 && data.OData__x0039_0DayEmailSent) reason = '90-day email already sent';\n    else reason = 'Did not match any trigger condition';\n  }\n\n  results.push({ json: { ...data, trigger, reason } });\n}\n\nreturn results;"
