      "parameters": {
        "jsCode": "const rows = $input.first().json.noneRows || [];\n\nif (rows.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\nconst tableRows = rows.map(r =>\n  `<tr><td style=\"padding:6px 12px;border:1px solid #ddd;\">${r.Id || ''}</td><td style=\"padding:6px 12px;border:1px solid #ddd;\">${r.Title || ''}</td><td style=\"padding:6px 12px;border:1px solid #ddd;\">${r.Email || ''}</td><td style=\"padding:6px 12px;border:1px solid #ddd;\">${r.HireDate ? r.HireDate.split('T')[0] : ''}</td><td style=\"padding:6px 12px;border:1px solid #ddd;\">${r.StartDate ? r.StartDate.split('T')[0] : ''}</td><td style=\"padding:6px 12px;border:1px solid #ddd;\">${r.reason || ''}</td></tr>`\n).join('');\n\nconst html = `<html><body style=\"font-family:Arial,sans-serif;\"><h2>Daily Onboarding Workflow Summary</h2><p>The following <b>${rows.length}</b> active employee(s) did not match any trigger condition in today's run:</p><table style=\"border-collapse:collapse;border:1px solid #ddd;\"><thead><tr style=\"background:#f4f4f4;\"><th style=\"padding:6px 12px;border:1px solid #ddd;text-align:left;\">ID</th><th style=\"padding:6px 12px;border:1px solid #ddd;text-align:left;\">Name</th><th style=\"padding:6px 12px;border:1px solid #ddd;text-align:left;\">Email</th><th style=\"padding:6px 12px;border:1px solid #ddd;text-align:left;\">Hire Date</th><th style=\"padding:6px 12px;border:1px solid #ddd;text-align:left;\">Start Date</th><th style=\"padding:6px 12px;border:1px solid #ddd;text-align:left;\">Reason</th></tr></thead><tbody>${tableRows}</tbody></table><p style=\"color:#888;font-size:12px;margin-top:24px;\">Automated message from the RAH onboarding workflow.</p></body></html>`;\n\nreturn [{ json: { summaryHtml: html, count: rows.length, skip: false } }];"
      },
