    {
      "parameters": {
        "jsCode": "function daysBetween(date1, date2) {\n  const diff = new Date(date1).getTime() - new Date(date2).getTime();\n  return Math.floor(diff / (1000 * 60 * 60 * 24));\n}\n\nconst today = new Date();\nconst todayStr = today.toISOString().split('T')[0];\n\nconst yesterday = new Date();\nyesterday.setDate(today.getDate() - 1);\nconst yesterdayStr = yesterday.toISOString().split('T')[0];\n\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n\n  const hireDate = data.HireDate ? data.HireDate.split('T')[0] : null;\n  const startDate = data.StartDate ? data.StartDate.split('T')[0] : null;\n\n  const daysSinceStart = startDate ? daysBetween(today, startDate) : null;\n\n  let trigger = null;\n  let reason = '';\n\n  // 1. New Hire (HireDate is today or yesterday)\n  if (hireDate && (hireDate === todayStr || hireDate === yesterdayStr)) {\n    trigger = 'NEW_HIRE';\n  }\n  // 2. First Shift (StartDate = yesterday)\n  else if (startDate && startDate === yesterdayStr) {\n    trigger = 'FIRST_SHIFT';\n  }\n  // 3. 30-day check-in\n  else if (\n    daysSinceStart !== null &&\n    daysSinceStart >= 30 &&\n    daysSinceStart < 60 &&\n    !data.OData__x0033_0DayEmailSent\n  ) {\n    trigger = '30_DAY';\n  }\n  // 4. 60-day check-in\n  else if (\n    daysSinceStart !== null &&\n    daysSinceStart >= 60 &&\n    daysSinceStart < 90 &&\n    !data.OData__x0036_0DayEmailSent\n  ) {\n    trigger = '60_DAY';\n  }\n  // 5. 90-day check-in\n  else if (\n    daysSinceStart !== null &&\n    daysSinceStart >= 90 &&\n    !data.OData__x0039_0DayEmailSent\n  ) {\n    trigger = '90_DAY';\n  }\n  // No trigger matched — figure out why\n  else {\n    trigger = 'NONE';\n\n    if (!hireDate && !startDate) {\n      reason = 'No HireDate or StartDate on record';\n    } else if (!startDate) {\n      reason = 'No StartDate — cannot evaluate shift/day milestones';\n    } else if (daysSinceStart !== null && daysSinceStart < 30) {\n      reason = `Only ${daysSinceStart} days since StartDate — too early for 30-day milestone`;\n    } else if (\n      daysSinceStart >= 30 && daysSinceStart < 60 &&\n      data.OData__x0033_0DayEmailSent\n    ) {\n      reason = '30-day email already sent';\n    } else if (\n      daysSinceStart >= 60 && daysSinceStart < 90 &&\n      data.OData__x0036_0DayEmailSent\n    ) {\n      reason = '60-day email already sent';\n    } else if (\n      daysSinceStart >= 90 &&\n      data.OData__x0039_0DayEmailSent\n    ) {\n      reason = '90-day email already sent';\n    } else {\n      reason = 'Did not match any trigger condition';\n    }\n  }\n\n  results.push({\n    json: {\n      ...data,\n      trigger,\n      reason\n    }\n  });\n}\n\nreturn results;"
      },
